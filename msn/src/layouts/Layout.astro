---
interface Props {
  title?: string;
}
const { title = 'Marie Nussbaum — Clinical Psychologist & Psychoanalyst' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #fdfcfa;
        --text: #1c1c1c;
        --muted: #666;
        --accent: #6b7c5c;
        --border: #e0ddd7;
        --max: 720px;
      }

      body {
        font-family: 'Georgia', Georgia, serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.75;
        font-size: 1.05rem;
      }

      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }

      nav {
        border-bottom: 1px solid var(--border);
        padding: 1rem 1.5rem;
      }
      nav .inner {
        max-width: var(--max);
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 2rem;
        flex-wrap: wrap;
      }
      nav .brand {
        font-weight: bold;
        font-size: 1rem;
        color: var(--text);
        margin-right: auto;
        text-decoration: none;
      }
      nav a { font-size: 0.9rem; color: var(--muted); }
      nav a:hover { color: var(--text); text-decoration: none; }

      main {
        max-width: var(--max);
        margin: 0 auto;
        padding: 3rem 1.5rem 6rem;
      }

      footer {
        border-top: 1px solid var(--border);
        text-align: center;
        padding: 2rem 1.5rem;
        font-size: 0.85rem;
        color: var(--muted);
      }

      h1 { font-size: 2rem; line-height: 1.2; margin-bottom: 1rem; font-weight: normal; }
      h2 { font-size: 1.3rem; margin: 2.5rem 0 0.75rem; font-weight: bold; }
      h3 { font-size: 1.05rem; margin: 1.5rem 0 0.5rem; font-weight: bold; }
      p { margin-bottom: 1rem; }
      ul, ol { margin: 0.5rem 0 1rem 1.5rem; }
      li { margin-bottom: 0.3rem; }
      hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
    </style>
  </head>
  <body>
    <nav>
      <div class="inner">
        <a class="brand" href={`${base}/`}>Marie Nussbaum</a>
        <a href={`${base}/approach`}>Approach</a>
        <a href={`${base}/contact`}>Contact</a>
        <a href={`${base}/questions`}>FAQ</a>
        <a href={`${base}/posts`}>Posts</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      Marie Nussbaum 2025 © All rights reserved
    </footer>
  </body>
</html>