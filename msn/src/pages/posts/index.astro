---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const base = import.meta.env.BASE_URL;
---
<Layout title="Posts — Marie Nussbaum">
  <h1>Posts</h1>
  <ul style="list-style: none; padding: 0; margin-top: 1.5rem;">
    {posts.map(post => (
      <li style="display: flex; justify-content: space-between; align-items: baseline; padding: 0.6rem 0; border-bottom: 1px solid var(--border); gap: 1rem; flex-wrap: wrap;">
        <a href={`${base}/posts/${post.slug}`}>{post.data.title}</a>
        <span style="font-size: 0.85rem; color: var(--muted); white-space: nowrap;">{post.data.date}</span>
      </li>
    ))}
  </ul>
</Layout>