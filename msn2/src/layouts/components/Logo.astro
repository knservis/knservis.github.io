---
import { Image } from "astro:assets";
import config from "@/config/config.json";
import { getRelativeLocaleUrl } from "astro:i18n";
const { src } = Astro.props;
const locale = (
  Astro.currentLocale ?? (Astro.url.pathname.startsWith("/fr") ? "fr" : "en")
) as "en" | "fr";
const homeHref = getRelativeLocaleUrl(locale, "/");
const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;
---

<a href={homeHref} class="navbar-brand block">
  {
    src || logo ? (
      <Image
        width={logo_width.replace("px", "") * 2}
        height={logo_height.replace("px", "") * 2}
        src={src ? src : logo}
        alt={title}
        style={{
          height: logo_height.replace("px", "") + "px",
          width: logo_width.replace("px", "") + "px",
        }}
      />
    ) : logo_text ? (
      logo_text
    ) : (
      title
    )
  }
</a>
