---
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { BsArrowRightCircle } from "react-icons/bs";

type Props = {
  authors: CollectionEntry<"enAuthors" | "frAuthors">[];
};
const { authors } = Astro.props;

const locale = (
  Astro.currentLocale ?? (Astro.url.pathname.startsWith("/fr") ? "fr" : "en")
) as "en" | "fr";
const authorHref = (id: string) => getRelativeLocaleUrl(locale, `/authors/${id}`);
---

<div class="row justify-center">
  {
    authors.map((author) => (
      <div class="col-12 mb-8 sm:col-6 md:col-4">
        {author.data.image && (
          <div class="mb-4">
            <Image
              src={author.data.image}
              alt={author.data.title}
              height={150}
              width={150}
              class="mx-auto rounded-lg"
            />
          </div>
        )}
        <h3 class="h4 mt-8 mb-3">
          <a
            href={authorHref(author.id)}
            class="block hover:text-primary transition duration-200"
          >
            {author.data.title}
          </a>
        </h3>
        {author.body && (
          <p class="mb-3" set:text={markdownify(author.body.slice(0, 100))} />
        )}

        <a
          href={authorHref(author.id)}
          class="inline-flex items-center text-primary transition duration-200 hover:opacity-70"
        >
          Read More <BsArrowRightCircle className="inline ml-2" />
        </a>
      </div>
    ))
  }
</div>
