---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import AuthorSingle from "@/partials/AuthorSingle.astro";

export async function getStaticPaths() {
  const AUTHORS_FOLDER = "frAuthors";
  const authors = await getSinglePage(AUTHORS_FOLDER);

  return authors.map((author) => ({
    params: {
      single: author.id,
    },
    props: { author },
  }));
}

const { author } = Astro.props;
const { title, meta_title, image, description } = author.data;
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <AuthorSingle author={author} />
</Base>
